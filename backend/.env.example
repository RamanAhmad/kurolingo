# ─── Kurdolingo Backend — Konfiguration ───────────────────────────────────────
# Kopiere diese Datei nach .env und passe die Werte an.
# Niemals .env in Git einchecken!

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Sicherheit (REQUIRED in Produktion) ──────────────────────────────────────
# Generieren mit:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mindestens 64 zufällige Zeichen. Nie den Beispielwert verwenden!
JWT_SECRET=change-this-in-production-use-64-random-hex-chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Entwicklung:
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Produktion (Beispiel):
# ALLOWED_ORIGINS=https://kurdolingo.de,https://www.kurdolingo.de

# ── Trust Proxy ───────────────────────────────────────────────────────────────
# REQUIRED in Produktion hinter nginx / Cloudflare.
# Ohne dies ist req.ip immer 127.0.0.1 — Rate Limiting funktioniert nicht.
#
#   false      → Kein Proxy (Entwicklung)
#   1          → Ein Proxy (nginx auf demselben Server) — häufigster Fall
#   2          → Zwei Proxies (Cloudflare → nginx → App)
#   10.0.0.0/8 → Bestimmter CIDR (erweitert)
#
TRUST_PROXY=false
# Produktion: TRUST_PROXY=1
